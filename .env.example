# ── 必填 ──────────────────────────────────────────────────────────────────────
# Anthropic API Key（驱动所有认知模块）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 使用的 Claude 模型（默认 claude-sonnet-4-6）
CLAUDE_MODEL=claude-sonnet-4-6

# ── 可选：多 Key 轮转（高并发时防止单 key 超限）────────────────────────────────
# ANTHROPIC_API_KEY_2=sk-ant-xxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY_3=sk-ant-xxxxxxxxxxxxxxxx

# ── 可选：快速层 LLM（Perception/OCC/WorldEngine，使用 qwen3-max 降低成本）────
# FAST_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# FAST_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# FAST_LLM_MODEL=qwen3-max

# ── 可选：自定义 Anthropic 端点（代理/镜像）────────────────────────────────────
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
